{
  "name": "dekes-signed-runtime-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "prestart": "node scripts/validate-runtime-env.mjs",
    "start": "prisma migrate deploy && next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
