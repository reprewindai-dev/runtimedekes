DATABASE_URL="postgresql://user:password@localhost:5432/dekes_saas"
JWT_SECRET="change-me"
SESSION_SECRET="change-me"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# UTM Attribution Defaults (optional)
NEXT_PUBLIC_UTM_SOURCE=""
NEXT_PUBLIC_UTM_MEDIUM=""
NEXT_PUBLIC_UTM_CAMPAIGN=""
NEXT_PUBLIC_UTM_TERM=""
NEXT_PUBLIC_UTM_CONTENT=""

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

SERPAPI_API_KEY=""

# ── ECOBE Engine Integration ──────────────────────────────────────────────────
# Legacy endpoints (optimize/report/analytics) — uses Bearer ECOBE_ENGINE_API_KEY
ECOBE_ENGINE_URL="http://localhost:4000"
ECOBE_ENGINE_API_KEY=""

# Modern ECOBE API — uses Bearer ECOBE_API_KEY for /prospects, /tenants, /demos, /handoffs, /route, /workloads
# When running locally: set to http://localhost:4000 (ECOBE engine port)
# When deployed: set to your production ECOBE engine URL
ECOBE_API_BASE_URL="http://localhost:4000"
ECOBE_API_KEY=""

# Shared API key — MUST match DEKES_API_KEY in the ECOBE engine .env
DEKES_API_KEY="change-me-shared-with-ecobe"

# Optional direct URL overrides (leave blank to use ECOBE_ENGINE_URL defaults)
ECOBE_OPTIMIZE_URL=""
ECOBE_REPORT_URL=""
ECOBE_ANALYTICS_URL=""

# Carbon-aware routing (POST /api/v1/route). Uses ECOBE_API_BASE_URL if blank.
ECOBE_ROUTE_BASE_URL=""

# ECOBE dashboard URL — used to construct decision replay links in the UI
NEXT_PUBLIC_ECOBE_DASHBOARD_URL="http://localhost:3001"

# Webhook secret — ECOBE sends this in event/handoff-status webhooks
ECOBE_WEBHOOK_SECRET="change-me-shared-with-ecobe"

# Upstash Infrastructure
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
UPSTASH_VECTOR_REST_URL=""
UPSTASH_VECTOR_REST_TOKEN=""

# OpenAI
OPENAI_API_KEY=""

# Jobs (Legacy - keep for compatibility)
JOBS_ENDPOINT_URL="${NEXT_PUBLIC_APP_URL}/api/jobs/runner"
JOBS_SECRET="change-me"
